{
  "name": "upcycling-patterns-site",
  "version": "1.5.1",
  "private": true,
  "description": "Static Erasmus+ KA210-SCH project website with CMS data, PWA support, tests, and build helpers.",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.13.0",
  "scripts": {
    "build": "node scripts/build.js",
    "validate:json": "node scripts/validate-json.js",
    "generate:og": "node scripts/generate-og.js",
    "watch": "node scripts/watch.js",
    "test": "node --test tests/*.test.js",
    "test:a11y": "node --test tests/a11y.test.js",
    "test:smoke": "node --test tests/smoke.test.js",
    "test:i18n": "node --test tests/i18n.test.js"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "sharp": "^0.35.1"
  }
}
